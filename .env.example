# LLM Provider API Keys
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# --- Tiptap Cloud: Server AI Toolkit ---
# Base URL for the Server AI Toolkit API.
TIPTAP_CLOUD_AI_API_URL=https://api.tiptap.dev/v3/ai
# App ID for the Server AI Toolkit API (sent as the X-App-Id header).
TIPTAP_CLOUD_AI_APP_ID=your-app-id
# Non-streaming demos: legacy secret-based auth (HS256). Used to mint the JWT
# that authenticates Server AI Toolkit calls.
TIPTAP_CLOUD_AI_SECRET=your-secret-key
# Streaming demos only: Tiptap Access Control (ES256). PKCS#8 PEM signing key +
# environment id from the Tiptap dashboard.
TIPTAP_AUTH_PRIVATE_KEY=your-es256-private-key-pem
TIPTAP_AUTH_ENVIRONMENT_ID=env_your-environment-id

# --- Tiptap Cloud: Collaboration (Hocuspocus document server) ---
# Document server id + secret, used to mint the document-scoped collab JWT
# handed to the browser provider.
TIPTAP_CLOUD_DOCUMENT_SERVER_ID=your-tiptap-cloud-document-server-id
TIPTAP_CLOUD_SECRET=your-collab-secret
# Optionally overwrite the base url for the collab instance.
# TIPTAP_CLOUD_COLLAB_BASE_URL=https://your-on-prem-instance.com

# --- Tiptap Cloud: Document management REST API (server-comments demo) ---
TIPTAP_CLOUD_DOCUMENT_MANAGEMENT_API_SECRET=your-document-management-api-secret
