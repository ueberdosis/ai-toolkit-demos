# LLM Provider API Keys
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# --- Tiptap Cloud: Server AI Toolkit (access-control auth, ES256) ---
# Base URL for the Server AI Toolkit API.
TIPTAP_CLOUD_AI_API_URL=https://api.tiptap.dev/v3/ai
# ES256 signing key (PKCS#8 PEM) + environment id from the Tiptap dashboard.
# Used to mint the JWT that authenticates Server AI Toolkit calls.
TIPTAP_AUTH_PRIVATE_KEY=your-es256-private-key-pem
TIPTAP_AUTH_ENVIRONMENT_ID=env_your-environment-id

# --- Tiptap Cloud: Collaboration (Hocuspocus document server) ---
# Document server id + secret, used to mint the document-scoped collab JWT
# handed to the browser provider.
TIPTAP_CLOUD_DOCUMENT_SERVER_ID=your-tiptap-cloud-document-server-id
TIPTAP_CLOUD_SECRET=your-collab-secret
# Optionally overwrite the base url for the collab instance.
# TIPTAP_CLOUD_COLLAB_BASE_URL=https://your-on-prem-instance.com
